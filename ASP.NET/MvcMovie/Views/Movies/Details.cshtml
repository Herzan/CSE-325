@model MvcMovie.Models.Movie

@{
    ViewData["Title"] = "Details";
}

<h1 class="mt-4">Movie Details</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Title</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Title)</dd>
            
            <dt class="col-sm-3">Release Date</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.ReleaseDate)</dd>
            
            <dt class="col-sm-3">Genre</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Genre)</dd>
            
            <dt class="col-sm-3">Price</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Price)</dd>
            
            <dt class="col-sm-3">Rating</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Rating)</dd>
        </dl>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>